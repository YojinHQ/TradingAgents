# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=

# Data vendors
# JINTEL_API_KEY: primary backend (GraphQL endpoint at api.jintel.ai). When
# unset, every analyst tool call falls through to yfinance automatically with
# a WARNING log entry; the framework still works without this key.
# Get a key at https://api.jintel.ai
JINTEL_API_KEY=

# ALPHA_VANTAGE_API_KEY: optional second fallback after yfinance. Free tier at
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=
